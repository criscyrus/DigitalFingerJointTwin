within FingerJointTwin;

package Functions "Mathematical utility functions"
  extends Modelica.Icons.UtilitiesPackage;

annotation(Documentation(info="
<html>
<body>
  <h3>Functions</h3>
  <p>Mathematical utility functions used internally by the FingerJointTwin library.</p>
  <ul>
    <li><b>smoothMax</b>: Smooth approximation of max(0, x) for numerically stable contact and limit modeling</li>
  </ul>
</body>
</html>"));
end Functions;
